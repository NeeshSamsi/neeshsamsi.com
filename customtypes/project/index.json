{
  "format": "page",
  "id": "project",
  "label": "Project",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Primary Cover Image (Mockup)",
          "constraint": {},
          "thumbnails": []
        }
      },
      "hoverImage": {
        "type": "Image",
        "config": {
          "label": "Secondary Cover Image (Hover)",
          "constraint": {},
          "thumbnails": []
        }
      },
      "subtitle": {
        "type": "Text",
        "config": {
          "label": "Subtitle",
          "placeholder": "Ecommerce, UI UX, Visual design"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Website Redesign for ..."
        }
      },
      "type": {
        "type": "Select",
        "config": {
          "label": "Project Type",
          "placeholder": "",
          "options": ["Exploration & Play", "Client Work"],
          "default_value": "Exploration & Play"
        }
      },
      "publishedDate": {
        "type": "Date",
        "config": {
          "label": "Published Date",
          "placeholder": "Today"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "external_link_callout": {
              "type": "SharedSlice"
            },
            "image_content": {
              "type": "SharedSlice"
            },
            "project_overview": {
              "type": "SharedSlice"
            },
            "rich_text": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
